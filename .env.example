# Database (single Prisma schema, PostgreSQL for all environments)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/todolist?schema=public"

# Auth (required)
JWT_SECRET="replace-with-a-strong-secret"

# Cron auth for /api/cron/daily-tasks (required only if cron endpoint is used)
CRON_SECRET="replace-with-a-strong-cron-secret"

# Environment
NODE_ENV="development"

# Cookie behavior
# Use "false" only for plain HTTP local/dev.
# Keep "true" in production behind HTTPS.
COOKIE_SECURE="false"

# Reverse proxy hops for correct client IP handling:
# "false" (default), "true" (1 proxy), or a positive integer string.
TRUST_PROXY="false"

# Frontend base URL used in email links (invitations employés, reset mot de passe)
# FRONTEND_URL="http://localhost:8080"
# APP_URL="http://localhost:8080"

# E-mail : adresse d'envoi et SMTP (invitations employés, réinitialisation mot de passe)
# Sans SMTP configuré, en dev un compte Ethereal (faux SMTP) est utilisé.
# Redémarrer le serveur après toute modification des variables SMTP.
#
# Exemple Outlook / Outlook.com / Microsoft 365 :
# EMAIL_FROM="votre-adresse@outlook.com"
# SMTP_HOST="smtp-mail.outlook.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="votre-adresse@outlook.com"
# SMTP_PASS="votre-mot-de-passe"
# (Si double authentification : créer un "mot de passe d'application" sur account.microsoft.com)
#
# Exemple générique :
# EMAIL_FROM="noreply@votredomaine.com"
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="votre-compte@smtp.example.com"
# SMTP_PASS="mot-de-passe-app-smtp"

# Production CORS allowlist (comma-separated)
# ALLOWED_ORIGINS="https://app.example.com"

# Optional server port (production default is 3000)
# PORT=3000

# Optional log hashing secret for correlation without PII
# LOG_HASH_SECRET="replace-with-a-strong-secret"
