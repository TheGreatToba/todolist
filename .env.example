# Database (single Prisma schema, PostgreSQL for all environments)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/todolist?schema=public"

# Auth (required)
JWT_SECRET="replace-with-a-strong-secret"

# Cron auth for /api/cron/daily-tasks (required only if cron endpoint is used)
CRON_SECRET="replace-with-a-strong-cron-secret"

# Environment
NODE_ENV="development"

# Cookie behavior
# Use "false" only for plain HTTP local/dev.
# Keep "true" in production behind HTTPS.
COOKIE_SECURE="false"

# Reverse proxy hops for correct client IP handling:
# "false" (default), "true" (1 proxy), or a positive integer string.
TRUST_PROXY="false"

# Frontend base URL used in email links
# FRONTEND_URL="http://localhost:8080"
# APP_URL="http://localhost:8080"

# Production CORS allowlist (comma-separated)
# ALLOWED_ORIGINS="https://app.example.com"

# Optional server port (production default is 3000)
# PORT=3000

# Optional log hashing secret for correlation without PII
# LOG_HASH_SECRET="replace-with-a-strong-secret"
